<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/perm_dialog_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/perm_dialog_desc"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingBottom="20dp" />

        <!-- YÖNTEM 1: ROOT (önerilen - sadece rooted cihazda aktif buton) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_root_method_title"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurface"
                    android:paddingBottom="6dp" />

                <TextView
                    android:id="@+id/tvRootDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_root_method_desc"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingBottom="10dp" />

                <!-- Root butonu: sadece rooted cihazda görünür -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantRoot"
                    style="@style/Widget.App.Button.Neutral"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/perm_grant_root"
                    android:textAllCaps="false"
                    android:visibility="gone"
                    app:cornerRadius="10dp" />

                <!-- Root yoksa not (Kotlin'den doldurulur) -->
                <TextView
                    android:id="@+id/tvRootInfoNoRoot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- YÖNTEM 2: ADB -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_adb_method_title"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:paddingBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_adb_steps"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.6"
                    android:paddingBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_code_block"
                    android:padding="12dp"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvAdbCommand"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:textSize="9.5sp"
                        android:singleLine="true"
                        android:scrollHorizontally="true"
                        android:ellipsize="none"
                        android:textIsSelectable="true"
                        android:textColor="?attr/colorOnSurface" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyAdb"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_copy"
                        android:contentDescription="@string/btn_copy" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/perm_adb_info_hint"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckPermission"
            style="@style/Widget.App.Button.Neutral"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="@string/perm_check_button"
            android:textAllCaps="false"
            app:cornerRadius="10dp" />

    </LinearLayout>
</ScrollView>
