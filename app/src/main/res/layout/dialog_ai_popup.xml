<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="20dp">

    <!-- BAŞLIK SATIRI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/ai_popup_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_close" />
    </LinearLayout>

    <!-- LOG DOSYASI SEÇİMİ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ai_select_log_file"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="sans-serif"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/layoutLogSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnPrevLog"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_arrow_left"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Önceki" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvSelectedLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="log_file.txt"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="middle" />

                    <TextView
                        android:id="@+id/tvFileSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="0.00 MB"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="center" />

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnNextLog"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_arrow_right"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Sonraki" />

            </LinearLayout>

            <!-- Boyut uyarısı -->
            <TextView
                android:id="@+id/tvSizeWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ai_file_too_large"
                android:textColor="@color/red_stop"
                android:textSize="12sp"
                android:paddingTop="6dp"
                android:visibility="gone" />

            <!-- Log bulunamadı mesajı -->
            <TextView
                android:id="@+id/tvNoLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ai_no_log_file"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="8dp"
                android:visibility="gone" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- SORUN AÇIKLAMASI -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ai_problem_label"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="sans-serif"
        android:paddingBottom="6dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        style="@style/Widget.App.TextInputLayout"
        android:hint="@string/ai_problem_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etProblemDescription"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:maxLines="6" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- GÖNDER BUTONU -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendToAi"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/ai_send_button"
        android:textStyle="bold"
        android:background="@drawable/gradient_ai_button"
        app:backgroundTint="@null"
        app:cornerRadius="12dp" />

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

</LinearLayout>
