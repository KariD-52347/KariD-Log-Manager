<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Baslik -->
        <TextView
            android:id="@+id/tvWelcomeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/first_launch_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/welcome_subtitle"
            android:textSize="13sp"
            android:gravity="center"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingBottom="20dp" />

        <!-- Amac karti -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_purpose_title"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_purpose_desc"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Nasil kullanilir karti -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_howtouse_title"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingBottom="6dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/info_how_to_use_desc"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Kayit turleri karti -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_logtypes_title"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingBottom="10dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp">
                    <View android:layout_width="10dp" android:layout_height="10dp" android:layout_marginTop="4dp" android:layout_marginEnd="8dp" android:background="@drawable/circle_green" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/soft_log_title" android:textStyle="bold" android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/soft_log_desc" android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="8dp">
                    <View android:layout_width="10dp" android:layout_height="10dp" android:layout_marginTop="4dp" android:layout_marginEnd="8dp" android:background="@drawable/circle_blue" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/normal_log_title" android:textStyle="bold" android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/normal_log_desc" android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <View android:layout_width="10dp" android:layout_height="10dp" android:layout_marginTop="4dp" android:layout_marginEnd="8dp" android:background="@drawable/circle_yellow" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/deep_log_title" android:textStyle="bold" android:textSize="13sp" android:fontFamily="sans-serif-medium" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/deep_log_desc" android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- READ_LOGS Izin Karti (Zorunlu) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_root_perm_title"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_root_perm_desc"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingBottom="12dp" />

                <!-- İzin durumu -->
                <TextView
                    android:id="@+id/tvReadLogsStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingBottom="10dp" />

                <!-- Root varsa otomatik izin butonu -->
                <LinearLayout
                    android:id="@+id/layoutLaunchRoot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantRootPerm"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/btn_grant_root_perm"
                        android:textAllCaps="false"
                        android:layout_marginBottom="10dp"
                        app:cornerRadius="10dp" />
                </LinearLayout>

                <!-- Gizli ADB alanları (ID gerekiyor) -->
                <TextView
                    android:id="@+id/tvAdbCommandLaunch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCopyAdbLaunch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <!-- Custom ROM notu -->
                <TextView
                    android:id="@+id/tvRomNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_rom_note"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.4"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingTop="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Dosya Izni Karti -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_permission_file_title"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingBottom="4dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_permission_file_desc"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.4"
                    android:paddingBottom="10dp" />

                <TextView
                    android:id="@+id/tvSelectedFolder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:paddingBottom="6dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFilePermission"
                    style="@style/Widget.App.Button.Neutral"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/btn_file_permission"
                    android:textAllCaps="false"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bildirim Izni Karti -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_permission_notif_title"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:paddingBottom="4dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_permission_notif_desc"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.4"
                    android:paddingBottom="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNotificationPermission"
                    style="@style/Widget.App.Button.Neutral"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/btn_notification_permission"
                    android:textAllCaps="false"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Okudum checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/checkboxAgreement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/welcome_agree_checkbox"
            android:textSize="14sp"
            android:paddingStart="4dp"
            android:layout_marginBottom="12dp" />

        <!-- Baslayalim butonu -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClose"
            style="@style/Widget.App.Button.Neutral"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_lets_go"
            android:textStyle="bold"
            android:enabled="false"
            android:textAllCaps="false"
            app:cornerRadius="12dp" />

        <View android:layout_width="match_parent" android:layout_height="32dp" />
    </LinearLayout>
</ScrollView>
