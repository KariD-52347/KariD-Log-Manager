<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Logcat okumak için (root gerektirmez, API 29+ uygulamanın kendi loglarını okuyabilir) -->
    <uses-permission android:name="android.permission.READ_LOGS" tools:ignore="ProtectedPermissions" />

    <!-- Bildirim izni (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Dosya yönetimi (SAF kullanacağız ama genel erişim için) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- İnternet (Gemini API için) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Cihaz durumu okuma -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KariDLogManager"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="31">

        <!-- Ana ekran -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Ayarlar ekranı -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Log geçmişi ekranı -->
        <activity
            android:name=".ui.LogHistoryActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Bilgi ekranı -->
        <activity
            android:name=".ui.InfoActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- Foreground log servisi -->
        <service
            android:name=".service.LogService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Bildirimden "Durdur" butonuna basıldığında çalışacak BroadcastReceiver -->
        <receiver
            android:name=".receiver.StopLogReceiver"
            android:exported="false" />

        <!-- Log dosyalarını paylaşmak için FileProvider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
